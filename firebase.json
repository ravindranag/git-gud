{
  "functions": [
    {
      "source": "apps/functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local",
        "firebase*.json"
      ],
      "predeploy": [
        "bun run --cwd \"$RESOURCE_DIR\" build"
      ]
    }
  ],
  "hosting": {
    "public": "apps/web/dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "predeploy": [
      "bun run --cwd \"$RESOURCE_DIR\" build"
    ]
  }
}
